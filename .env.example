# Copy to .env and edit as needed. .env is gitignored.

# Where Locus stores everything (genome, reference, annotation DBs, the DuckDB).
# Point this at an external SSD if you prefer:
# LOCUS_DATA_DIR=/Volumes/genome/locus-data

# Path to the DuckDB store queried by the MCP server and the SPA.
# LOCUS_DB_PATH=/Volumes/genome/locus-data/locus.duckdb

# Sample identity used to label outputs.
# LOCUS_SAMPLE_ID=matthew

# SPA backend (localhost only).
# LOCUS_API_HOST=127.0.0.1
# LOCUS_API_PORT=8787
